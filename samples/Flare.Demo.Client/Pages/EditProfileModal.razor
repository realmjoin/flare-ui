<div>
    <label class="form-label" for="name-input">Name</label>
    <input id="name-input" class="form-control" @bind="Name" />

    <div style="display: flex; gap: 0.5rem; justify-content: flex-end; margin-top: 1rem;">
        <button class="btn btn-outline-secondary" @onclick="Modal.Cancel">Cancel</button>
        <button class="btn btn-primary" @onclick="Save">Save</button>
    </div>
</div>

@code {
    [CascadingParameter] public ModalContext Modal { get; set; } = default!;
    [Parameter] public string CurrentName { get; set; } = "";

    private string Name = "";

    protected override void OnInitialized() => Name = CurrentName;

    private void Save()
    {
        if (string.IsNullOrWhiteSpace(Name)) return;
        Modal.Ok(Name);
    }
}
