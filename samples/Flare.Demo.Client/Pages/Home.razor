@page "/"
@rendermode InteractiveWebAssembly
@inject IFlareService Flare

<FlareProvider>

<PageTitle>Team Roster - Flare Demo</PageTitle>

<h1>Team Roster <small class="text-muted" style="font-size: 0.5em;">demo</small></h1>
<p class="lead">Manage your team — runs entirely in the browser via WebAssembly.</p>

<div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem;">
    <button class="btn btn-primary" @onclick="AddMember">Add member</button>
    <button class="btn btn-outline-secondary" @onclick="ImportMembers">Import members</button>
    @if (_members.Count > 0)
    {
        <button class="btn btn-outline-danger" @onclick="ClearAll">Clear all</button>
    }
</div>

@if (_members.Count == 0)
{
    <p class="text-muted">No team members yet. Add or import some!</p>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Name</th>
                <th>Role</th>
                <th style="width: 1px; white-space: nowrap;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var member in _members)
            {
                <tr>
                    <td>@member.Name</td>
                    <td>@member.Role</td>
                    <td style="white-space: nowrap;">
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => EditMember(member)">Edit</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveMember(member)">Remove</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

</FlareProvider>

@code {
    private record Member(string Name, string Role);

    private readonly List<Member> _members = new()
    {
        new("Alice Chen", "Engineering Lead"),
        new("Bob Martinez", "Designer"),
        new("Carol Zhang", "Backend Developer"),
    };

    private async Task AddMember()
    {
        var result = await Flare.ModalAsync<MemberModal>(new ModalOptions { Title = "Add Member" });

        if (result.Confirmed)
        {
            dynamic data = result.GetData<dynamic>()!;
            _members.Add(new Member((string)data.Name, (string)data.Role));
            await Flare.ToastAsync($"Added {data.Name}.", ToastLevel.Success);
        }
    }

    private async Task EditMember(Member member)
    {
        var result = await Flare.ModalAsync<MemberModal>(new ModalOptions
        {
            Title = "Edit Member",
            Parameters = new()
            {
                ["CurrentName"] = member.Name,
                ["CurrentRole"] = member.Role,
            },
        });

        if (result.Confirmed)
        {
            dynamic data = result.GetData<dynamic>()!;
            var i = _members.IndexOf(member);
            _members[i] = new Member((string)data.Name, (string)data.Role);
            await Flare.ToastAsync($"Updated {data.Name}.", ToastLevel.Success);
        }
    }

    private async Task RemoveMember(Member member)
    {
        var confirmed = await Flare.ConfirmAsync("Remove Member", $"Remove {member.Name} from the team?",
            new ConfirmOptions { Intent = ConfirmIntent.Danger, ConfirmText = "Remove" });

        if (confirmed)
        {
            _members.Remove(member);
            await Flare.ToastAsync($"{member.Name} removed.", ToastLevel.Success);
        }
    }

    private async Task ImportMembers()
    {
        var toast = Flare.StartLoadingToast("Importing members...", delayMs: 0);
        var imported = new[]
        {
            new Member("David Kim", "QA Engineer"),
            new Member("Eva Novak", "Product Manager"),
            new Member("Frank Osei", "DevOps"),
        };

        for (var i = 0; i <= 100; i += 10)
        {
            toast.Update(progress: i);
            await Task.Delay(80);
        }
        toast.Dispose();

        _members.AddRange(imported);
        await Flare.ToastAsync($"{imported.Length} members imported.", ToastLevel.Success);
    }

    private async Task ClearAll()
    {
        var confirmed = await Flare.ConfirmAsync("Clear Roster", "Remove all team members?", new ConfirmOptions
        {
            Intent = ConfirmIntent.Danger,
            ConfirmText = "Clear All",
            CancelText = "Keep",
        });

        if (confirmed)
        {
            _members.Clear();
            await Flare.ToastAsync("Roster cleared.", ToastLevel.Warning);
        }
    }
}
