@page "/"
@rendermode InteractiveWebAssembly
@inject IFlareService Flare

<FlareProvider>

<PageTitle>Team Roster - Flare Demo</PageTitle>

<h1>Team Roster <small class="text-muted" style="font-size: 0.5em;">demo</small></h1>
<p class="lead">Manage your team — runs entirely in the browser via WebAssembly.</p>

<div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem;">
    <button class="btn btn-primary" @onclick="AddMember">Add member</button>
    <FlareDebouncedButton class="btn btn-outline-secondary" OnAction="ImportMembers">Import members</FlareDebouncedButton>
    @if (_members.Count > 0)
    {
        <FlareConfirmButton class="btn btn-outline-danger" ArmedClass="btn-danger"
                            OnConfirmed="ClearAll">
            <Standby>Clear all<br />members</Standby>
            <Armed>Confirm clear</Armed>
        </FlareConfirmButton>
        <FlareClipboardButton class="btn btn-outline-secondary" Value="@RosterText" />
    }
</div>

@if (_members.Count == 0)
{
    <p class="text-muted">No team members yet. Add or import some!</p>
}
else
{
    <table class="table table-hover" style="vertical-align: middle;">
        <thead>
            <tr>
                <th>Name</th>
                <th>Role</th>
                <th>Added</th>
                <th>Scheduled</th>
                <th style="width: 1px; white-space: nowrap;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var member in _members)
            {
                <tr>
                    <td><FlareClipboard>@member.FirstName <b>@member.LastName</b></FlareClipboard></td>
                    <td>@member.Role</td>
                    <td style="white-space: nowrap; font-size: 0.85rem;"><FlareRelativeTime Value="@member.AddedUtc" /></td>
                    <td style="white-space: nowrap; font-size: 0.85rem;"><FlareRelativeDay Value="@member.ScheduledUtc" /></td>
                    <td style="white-space: nowrap;">
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => EditMember(member)">Edit</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveMember(member)">Remove</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

</FlareProvider>

@code {
    private record Member(string FirstName, string LastName, string Role, DateTimeOffset AddedUtc, DateTimeOffset ScheduledUtc);

    private readonly List<Member> _members = new()
    {
        new("Alice", "Chen", "Engineering Lead", DateTimeOffset.UtcNow.AddDays(-12), DateTimeOffset.UtcNow.AddDays(-2)),
        new("Bob", "Martinez", "Designer", DateTimeOffset.UtcNow.AddDays(-5), DateTimeOffset.UtcNow.AddDays(1).Date.AddHours(3)),
        new("Carol", "Zhang", "Backend Developer", DateTimeOffset.UtcNow.AddHours(-3), DateTimeOffset.UtcNow.AddDays(3).Date.AddHours(23)),
    };

    private async Task AddMember()
    {
        var result = await Flare.ModalAsync<MemberModal>(new ModalOptions { Title = "Add Member" });

        if (result.Confirmed)
        {
            dynamic data = result.GetData<dynamic>()!;
            _members.Add(new Member((string)data.FirstName, (string)data.LastName, (string)data.Role, DateTimeOffset.UtcNow, DateTimeOffset.UtcNow.AddDays(2)));
            await Flare.ToastAsync($"Added {data.FirstName} {data.LastName}.", ToastLevel.Success);
        }
    }

    private async Task EditMember(Member member)
    {
        var result = await Flare.ModalAsync<MemberModal>(new ModalOptions
        {
            Title = "Edit Member",
            Parameters = new()
            {
                ["CurrentFirstName"] = member.FirstName,
                ["CurrentLastName"] = member.LastName,
                ["CurrentRole"] = member.Role,
            },
        });

        if (result.Confirmed)
        {
            dynamic data = result.GetData<dynamic>()!;
            var i = _members.IndexOf(member);
            _members[i] = new Member((string)data.FirstName, (string)data.LastName, (string)data.Role, member.AddedUtc, member.ScheduledUtc);
            await Flare.ToastAsync($"Updated {data.FirstName} {data.LastName}.", ToastLevel.Success);
        }
    }

    private async Task RemoveMember(Member member)
    {
        var confirmed = await Flare.ConfirmAsync("Remove Member", $"Remove {member.FirstName} {member.LastName} from the team?",
            new ConfirmOptions { Intent = ConfirmIntent.Danger, ConfirmText = "Remove" });

        if (confirmed)
        {
            _members.Remove(member);
            await Flare.ToastAsync($"{member.FirstName} {member.LastName} removed.", ToastLevel.Success);
        }
    }

    private string RosterText =>
        string.Join("\n", _members.Select(m => $"{m.FirstName} {m.LastName} — {m.Role}"));

    private async Task ImportMembers()
    {
        var toast = Flare.StartLoadingToast("Importing members...", delayMs: 0);
        var imported = new[]
        {
            new Member("David", "Kim", "QA Engineer", DateTimeOffset.UtcNow, DateTimeOffset.UtcNow.AddDays(5)),
            new Member("Eva", "Novak", "Product Manager", DateTimeOffset.UtcNow, DateTimeOffset.UtcNow.AddDays(1).Date.AddHours(22)),
            new Member("Frank", "Osei", "DevOps", DateTimeOffset.UtcNow, DateTimeOffset.UtcNow.AddDays(7)),
        };

        for (var i = 0; i <= 100; i += 10)
        {
            toast.Update(progress: i);
            await Task.Delay(80);
        }
        toast.Dispose();

        _members.AddRange(imported);
        await Flare.ToastAsync($"{imported.Length} members imported.", ToastLevel.Success);
    }

    private async Task ClearAll()
    {
        _members.Clear();
        await Flare.ToastAsync("Roster cleared.", ToastLevel.Warning);
    }
}
