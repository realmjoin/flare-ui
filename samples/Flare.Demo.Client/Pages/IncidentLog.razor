@page "/incident-log"
@inject IFlareService Flare
@inject HttpClient Http

<FlareLoadingBar Active="_loading" Fixed />

<PageTitle>Incident Log - Flare Demo</PageTitle>

<h1>Incident Log <small class="text-muted" style="font-size: 0.5em;">demo</small></h1>
<p class="lead">Track and resolve incidents — all state lives on the server via REST API.</p>

<div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem;">
    <FlareDebouncedButton class="btn btn-primary" OnAction="FetchIncidents">Sync incidents</FlareDebouncedButton>
    <FlareDebouncedButton class="btn btn-outline-secondary" OnAction="SimulateIncident">Simulate incident</FlareDebouncedButton>
    @if (_incidents.Count > 0)
    {
        <FlareConfirmButton class="btn btn-outline-danger" ArmedClass="btn-danger"
                            UseModal ModalHeading="Acknowledge All"
                            ModalMessage="This will acknowledge all open incidents. Continue?"
                            OnConfirmed="AcknowledgeAll">
            <Standby>Acknowledge all</Standby>
        </FlareConfirmButton>
    }
</div>

@if (_incidents.Count == 0)
{
    <p class="text-muted">No incidents. Simulate one to get started!</p>
}
else
{
    <table class="table table-hover" style="vertical-align: middle;">
        <thead>
            <tr>
                <th>ID</th>
                <th>Service</th>
                <th>Message</th>
                <th>Severity</th>
                <th>Opened</th>
                <th style="width: 1px; white-space: nowrap;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var inc in _incidents)
            {
                <tr>
                    <td style="white-space: nowrap; font-family: monospace; font-size: 0.85rem;">
                        <FlareClipboard>@inc.Id</FlareClipboard>
                    </td>
                    <td>@inc.Service</td>
                    <td>@inc.Message</td>
                    <td>
                        <span class="badge @SeverityBadge(inc.Severity)">@inc.Severity</span>
                    </td>
                    <td style="white-space: nowrap; font-size: 0.85rem;">
                        <FlareRelativeTime Value="@inc.OpenedUtc" />
                    </td>
                    <td style="white-space: nowrap;">
                        <FlareConfirmButton class="btn btn-sm btn-outline-success" ArmedClass="btn-success"
                                            OnConfirmed="() => Resolve(inc)">
                            <Standby>Resolve</Standby>
                            <Armed>Confirm</Armed>
                        </FlareConfirmButton>
                        <FlareClipboardButton class="btn btn-sm btn-outline-secondary"
                                              Value="@($"{inc.Id} — {inc.Service}: {inc.Message}")">
                            Copy
                        </FlareClipboardButton>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private record Incident(string Id, string Service, string Message, string Severity, DateTimeOffset OpenedUtc);

    private bool _loading;
    private List<Incident> _incidents = [];

    protected override async Task OnInitializedAsync() => await FetchIncidents();

    private async Task FetchIncidents()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            _incidents = await Http.GetFromJsonAsync<List<Incident>>("/api/incidents") ?? [];
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SimulateIncident()
    {
        var response = await Http.PostAsync("/api/incidents/simulate", null);
        var inc = await response.Content.ReadFromJsonAsync<Incident>();

        if (inc is not null)
        {
            _incidents.Insert(0, inc);
            await Flare.ToastAsync($"New incident: {inc.Id}", inc.Severity == "Critical" ? ToastLevel.Error : ToastLevel.Warning);
        }
    }

    private async Task Resolve(Incident inc)
    {
        await Http.PostAsync($"/api/incidents/{inc.Id}/resolve", null);
        _incidents.Remove(inc);
        await Flare.ToastAsync($"Resolved {inc.Id}.", ToastLevel.Success);
    }

    private async Task AcknowledgeAll()
    {
        await Http.PostAsync("/api/incidents/acknowledge-all", null);
        var count = _incidents.Count;
        _incidents.Clear();
        await Flare.ToastAsync($"Acknowledged {count} incident(s).", ToastLevel.Success);
    }

    private static string SeverityBadge(string severity) => severity switch
    {
        "Critical" => "text-bg-danger",
        "Warning" => "text-bg-warning",
        _ => "text-bg-info",
    };
}
