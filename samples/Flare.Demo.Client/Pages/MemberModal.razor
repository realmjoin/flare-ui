@using System.ComponentModel.DataAnnotations

<EditForm Model="_model" OnValidSubmit="Save">
    <DataAnnotationsValidator />

    <div style="display: flex; gap: 0.5rem; margin-bottom: 1rem;">
        <div style="flex: 1;">
            <label class="form-label" for="first-name-input">First name</label>
            <InputText id="first-name-input" class="form-control" @bind-Value="_model.FirstName" />
            <ValidationMessage For="() => _model.FirstName" />
        </div>
        <div style="flex: 1;">
            <label class="form-label" for="last-name-input">Last name</label>
            <InputText id="last-name-input" class="form-control" @bind-Value="_model.LastName" />
            <ValidationMessage For="() => _model.LastName" />
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label">Role</label>
        <FlareTypeahead TItem="string"
                        Items="_roles"
                        TextSelector="r => r"
                        @bind-Value="_model.Role"
                        Placeholder="Search roles…"
                        DebounceMs="0"
                        MinLength="0" />
        <ValidationMessage For="() => _model.Role" />
    </div>

    <div class="mb-3">
        <label class="form-label">Skills</label>
        <FlareTagBox TItem="string"
                     Items="KnownSkills"
                     TextSelector="s => s"
                     CreateItem="s => s"
                     @bind-Values="_model.Skills"
                     Placeholder="Add skills…"
                     DebounceMs="0"
                     MinLength="0" />
        <ValidationMessage For="() => _model.Skills" />
    </div>

    <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
        <button type="button" class="btn btn-outline-secondary" @onclick="Modal.Cancel">Cancel</button>
        <button type="submit" class="btn btn-primary">Save</button>
    </div>
</EditForm>

@code {
    [CascadingParameter] public ModalContext Modal { get; set; } = default!;
    [Parameter] public string CurrentFirstName { get; set; } = "";
    [Parameter] public string CurrentLastName { get; set; } = "";
    [Parameter] public string? CurrentRole { get; set; }
    [Parameter] public IReadOnlyList<string> CurrentSkills { get; set; } = [];

    private MemberModel _model = new();

    static readonly List<string> _roles =
    [
        "Engineering Lead", "Backend Developer", "Frontend Developer", "Full-Stack Developer",
        "Designer", "UX Researcher", "Product Manager", "QA Engineer",
        "DevOps", "Site Reliability Engineer", "Data Scientist", "Security Engineer",
        "Engineering Manager", "Technical Writer", "Solutions Architect"
    ];

    public static readonly List<string> KnownSkills =
    [
        "C#", "TypeScript", "JavaScript", "Python", "Rust", "Go", "Java",
        "Blazor", "React", "Vue", "Angular", "ASP.NET", "Node.js",
        "PostgreSQL", "Redis", "Docker", "Kubernetes", "AWS", "Azure", "GCP",
        "GraphQL", "gRPC", "Terraform", "CI/CD", "Figma"
    ];

    protected override void OnInitialized()
    {
        _model = new MemberModel
        {
            FirstName = CurrentFirstName,
            LastName = CurrentLastName,
            Role = CurrentRole,
            Skills = CurrentSkills.ToList(),
        };
    }

    private void Save()
    {
        Modal.Ok(new { _model.FirstName, _model.LastName, _model.Role, _model.Skills });
    }

    private class MemberModel
    {
        [Required] public string FirstName { get; set; } = "";
        [Required] public string LastName { get; set; } = "";
        [Required] public string? Role { get; set; }
        [MinLength(1, ErrorMessage = "Add at least one skill.")]
        public IReadOnlyList<string> Skills { get; set; } = [];
    }
}
