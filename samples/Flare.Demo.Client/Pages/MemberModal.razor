<div>
    <div class="mb-3">
        <label class="form-label" for="name-input">Name</label>
        <input id="name-input" class="form-control" @bind="Name" />
    </div>

    <div class="mb-3">
        <label class="form-label" for="role-input">Role</label>
        <input id="role-input" class="form-control" @bind="Role" />
    </div>

    <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
        <button class="btn btn-outline-secondary" @onclick="Modal.Cancel">Cancel</button>
        <button class="btn btn-primary" @onclick="Save">Save</button>
    </div>
</div>

@code {
    [CascadingParameter] public ModalContext Modal { get; set; } = default!;
    [Parameter] public string CurrentName { get; set; } = "";
    [Parameter] public string CurrentRole { get; set; } = "";

    private string Name = "";
    private string Role = "";

    protected override void OnInitialized()
    {
        Name = CurrentName;
        Role = CurrentRole;
    }

    private void Save()
    {
        if (string.IsNullOrWhiteSpace(Name) || string.IsNullOrWhiteSpace(Role)) return;
        Modal.Ok(new { Name, Role });
    }
}
