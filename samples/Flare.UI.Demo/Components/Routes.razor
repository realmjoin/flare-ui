<Router AppAssembly="typeof(Program).Assembly"
    AdditionalAssemblies="new[] { typeof(Flare.UI.Demo.Client._Imports).Assembly }"
    NotFoundPage="typeof(Flare.UI.Demo.Client.Pages.NotFound)">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(Flare.UI.Demo.Client.Layout.MainLayout)" />
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>
