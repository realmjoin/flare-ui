@namespace Flare
@implements IAsyncDisposable

<div class="@BackdropClass()" @onclick="HandleBackdropClick" @onkeydown="HandleKeyDown" tabindex="-1" @ref="_backdrop">
    <div class="@DialogClass()" role="alertdialog" aria-modal="true"
         aria-labelledby="@_titleId" aria-describedby="@_descId"
         @onclick:stopPropagation="true" @ref="_dialog">
        @if (!string.IsNullOrEmpty(Instance.Title))
        {
            <h2 id="@_titleId" class="@(Headless ? null : "flare-confirm-title")">@Instance.Title</h2>
        }
        <p id="@_descId" class="@(Headless ? null : "flare-confirm-message")">@Instance.Message</p>
        <div class="@(Headless ? null : "flare-confirm-actions")">
            <button class="@(Headless ? null : "flare-confirm-cancel flare-btn")"
                    @onclick="() => Close(false)">
                @Instance.Options.CancelText
            </button>
            <button class="@(Headless ? null : "flare-confirm-ok flare-btn flare-btn-primary")"
                    @onclick="() => Close(true)">
                @Instance.Options.ConfirmText
            </button>
        </div>
    </div>
</div>
