@namespace Flare
@typeparam TItem
@implements IAsyncDisposable

<div class="@RootClass()"
     @ref="_root"
     @onclick="FocusInput"
     @onfocusin="HandleFocusIn">

    @* Selected tags *@
    @foreach (var item in _values)
    {
        var current = item;
        <span class="@(Headless ? null : $"flare-tagbox-tag{(Disabled ? "" : " flare-tagbox-tag-removable")}")"
              role="option"
              tabindex="@(Disabled ? -1 : 0)"
              aria-label="@($"{GetText(current)}, press Delete to remove")"
              @onkeydown="e => HandleTagKeyDown(e, current)"
              @onkeydown:preventDefault
              @onkeydown:stopPropagation
              @onpointerdown="() => RemoveTag(current)"
              @onpointerdown:stopPropagation>
            @if (TagTemplate is not null)
            {
                @TagTemplate(current)
            }
            else
            {
                @GetText(current)
            }
            @if (!Disabled)
            {
                <span class="@(Headless ? null : "flare-tagbox-tag-x")" aria-hidden="true">&times;</span>
            }
        </span>
    }

    @* Inline search input *@
    <input @ref="_input"
           @attributes="Attributes"
           type="text"
           role="combobox"
           autocomplete="off"
           aria-expanded="@(_isOpen && _items.Count > 0)"
           aria-activedescendant="@ActiveDescendant()"
           aria-controls="@_listboxId"
           aria-autocomplete="list"
           class="@InputClass()"
           placeholder="@CurrentPlaceholder()"
           disabled="@IsDisabled"
           @oninput="HandleInput"
           @onkeydown="HandleKeyDown"
           @onkeydown:stopPropagation="@_isOpen"
           @onblur="HandleBlur" />

    @* Dropdown *@
    @if (_isOpen && _items.Count > 0)
    {
        <ul id="@_listboxId" role="listbox" class="@ListboxClass()">
            @for (var i = 0; i < _items.Count; i++)
            {
                var index = i;
                var item = _items[i];
                <li id="@OptionId(index)"
                    role="option"
                    class="@OptionClass(index)"
                    aria-selected="@(index == _highlightedIndex)"
                    @onpointerdown="() => SelectItem(item)"
                    @onpointerdown:preventDefault>
                    @if (ItemTemplate is not null)
                    {
                        @ItemTemplate(item)
                    }
                    else
                    {
                        @GetText(item)
                    }
                </li>
            }
        </ul>
    }
    else if (_isOpen && _loading)
    {
        <div class="@(Headless ? null : "flare-tagbox-dropdown flare-tagbox-loading")">
            @(LoadingText ?? "Searching…")
        </div>
    }
    else if (_isOpen && _searched && _items.Count == 0 && !string.IsNullOrWhiteSpace(_text))
    {
        <div class="@(Headless ? null : "flare-tagbox-dropdown flare-tagbox-empty")">
            @if (CreateItem is not null)
            {
                <span>Press Enter to create <strong>@_text.Trim()</strong></span>
            }
            else
            {
                @(NotFoundText ?? "No results found")
            }
        </div>
    }
</div>
