@namespace Flare
@implements IDisposable

@if (_service.IsLoadingBarActive)
{
    <FlareLoadingBar Active="true" Fixed="true" Headless="_options.Headless" />
}

@ChildContent

@if (_service.LoadingToasts.Count > 0 || _service.Toasts.Count > 0)
{
    <div class="@ToastContainerClass()" role="region" aria-label="Notifications">
        @foreach (var lt in _service.LoadingToasts.ToList())
        {
            <FlareLoadingToast @key="lt.Id" Instance="lt" Headless="_options.Headless" />
        }
        @foreach (var toast in _service.Toasts.ToList())
        {
            <FlareToast @key="toast.Id"
                        Instance="toast"
                        Headless="_options.Headless"
                        OnDismiss="() => _service.DismissToast(toast.Id)" />
        }
    </div>
}

@if (_service.ActiveModal is not null)
{
    <FlareModal @key="_service.ActiveModal.Id"
                Instance="_service.ActiveModal"
                Headless="_options.Headless"
                OnClose="result => _service.CloseModal(result)" />
}

@if (_service.ActiveConfirm is not null)
{
    <FlareConfirm @key="_service.ActiveConfirm.Id"
                  Instance="_service.ActiveConfirm"
                  Headless="_options.Headless"
                  OnClose="confirmed => _service.CloseConfirm(confirmed)" />
}
